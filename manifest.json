{
  "manifest_version": 3,
  "name": "YouTube Auto Next",
  "version": "1.0",
  "permissions": [
    "scripting",
    "tabs",
    "webNavigation",
    "webRequest",
    "webRequestBlocking"
  ],
  "host_permissions": [
    "https://192.168.5.102:5000/",
    "wss://192.168.5.102:5000/"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src https://192.168.5.102:5000/ wss://192.168.5.102:5000/ *"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["socket.io.min.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
  {
    "resources": ["iframe.html"],
    "matches": ["<all_urls>"]
  }
]
}
